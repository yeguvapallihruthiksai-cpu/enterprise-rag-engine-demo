{
  "name": "enterprise-rag-engine-demo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "orchestrator"
  ],
  "scripts": {
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload --port 8001",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:orchestrator": "npm run dev --workspace orchestrator",
    "dev:web": "concurrently \"npm run dev:orchestrator\" \"npm run dev:frontend\"",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:orchestrator\" \"npm run dev:frontend\"",
    "build": "npm run build --workspace orchestrator && npm run build --workspace frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
